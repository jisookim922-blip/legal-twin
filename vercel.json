{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["hnd1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/trial-reminder",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/law-updates",
      "schedule": "0 3 * * 1"
    }
  ]
}
